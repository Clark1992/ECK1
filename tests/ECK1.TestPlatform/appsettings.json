{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "CommandsApi": {
    "BaseUrl": "http://localhost:30080/",
    "TimeoutSeconds": 30
  },
  "ProxyServices": {
    "Plugins": {
      "elasticsearch": "http://eck1-integration-proxy-elasticsearch-svc",
      "clickhouse": "http://eck1-integration-proxy-clickhouse-svc",
      "mongo": "http://eck1-integration-proxy-mongo-svc"
    }
  }
}
