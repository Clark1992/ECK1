{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Doppler": {
    "Token": "set in user secrets",
    "Projects": "eck1-global",
    "Config": "dev",
    "ApiHost": "https://api.doppler.com"
  },
  "Gateway": {
    "Namespace": "app-services",
    "RefreshIntervalSeconds": 30,
    "SwaggerPathTemplate": "/swagger/v1/swagger.json",
    "AsyncApiPath": "/.well-known/async-api.json",
    "StaticServices": []
  },
  "Kafka": {
    "BootstrapServers": "",
    "SchemaRegistryUrl": "",
    "User": "",
    "Secret": ""
  },
  "Zitadel": {
    "Authority": "",
    "Issuer": "",
    "ClientId": "",
    "RolePermissions": {
      "admin": [ "delete" ]
    }
  }
}
